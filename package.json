{
  "name": "cashportal-chatbot",
  "version": "0.1.0",
  "private": true,
  "description": "CashPortal demo banking website with a configurable web chatbot.",
  "main": "dist/index.js",
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "nodemon --exec ts-node src/index.ts",
    "demo": "CHATBOT_PLATFORM=web ts-node src/index.ts",
    "build": "tsc",
    "start:prod": "node dist/index.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "js-yaml": "^4.1.0",
    "node-telegram-bot-api": "^0.66.0",
    "openai": "^6.10.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.1",
    "@types/node-telegram-bot-api": "^0.64.9",
    "@types/pdf-parse": "^1.1.4",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
